# ── LLM API ──────────────────────────────────────────────────────────────────
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=unsloth/Meta-Llama-3.1-8B-Instruct:featherless-ai
HF_TOKEN=your_hf_token_here

# ── Environment connection (first variable that is set wins) ──────────────────
# Option A: Connect to the live HF Space (recommended for evaluation)
OPENENV_BASE_URL=https://p1yush-exe-bottlemedenv.hf.space

# Option B: Connect by HF Space ID
# HF_SPACE_ID=p1yush-exe/BottleMedENV

# Option C: Run locally via Docker (image must be built first)
# LOCAL_IMAGE_NAME=clinical-bench:latest

# ── Inference tuning (optional) ───────────────────────────────────────────────
SEED=42
TASK_INDEX=0
MAX_STEPS=8
TEMPERATURE=0.2
MAX_TOKENS=700

# ── Run all three tasks instead of one (set to 1 for full benchmark) ──────────
# RUN_ALL_TASKS=1
